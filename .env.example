# ── LLM 大模型配置 ──────────────────────────────────────────
# 复制此文件为 .env.local 并填入你的真实 API Key
# .env.local 不会被 git 提交（已在 .gitignore 中排除）

# API 基础地址（OpenAI 兼容协议）
# 阿里云百炼: https://dashscope.aliyuncs.com/compatible-mode/v1
# DeepSeek: https://api.deepseek.com/v1
# 智谱 GLM:  https://open.bigmodel.cn/api/paas/v4
VITE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# API Key（从阿里云百炼控制台获取）
VITE_LLM_API_KEY=sk-your-api-key-here

# 模型名称
# 阿里云百炼: qwen3.7-max
# DeepSeek: deepseek-chat
# 智谱 GLM:  glm-4-flash
VITE_LLM_MODEL=qwen3.7-max

# ── 阿里云百炼实时语音识别配置 ────────────────────────────────
# 后端代理地址（前端连接此地址，后端转发到百炼 DashScope）
VITE_ASR_PROXY_URL=/asr-proxy

# ── Tauri 后端代理配置（Rust 端环境变量）────────────────────
# 以下变量需要在系统环境变量或启动脚本中设置
# 用于 Rust 代理服务器（LLM/ASR/TTS/API 代理）

# 阿里云百炼 DashScope API Key（必填，用于 LLM/ASR/TTS 代理）
# DASHSCOPE_API_KEY=sk-your-api-key-here

# 后端服务器地址（可选，有默认值）
# BACKEND_BASE_URL=http://your-backend-server:8092

# 舌象 AI 服务地址（可选，有默认值）
# TONGUE_AI_URL=https://aitongue.maizhiyu.com