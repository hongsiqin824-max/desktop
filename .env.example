# ── LLM 大模型配置 ──────────────────────────────────────────
# 复制此文件为 .env.local 并填入你的真实 API Key
# .env.local 不会被 git 提交（已在 .gitignore 中排除）

# API 基础地址（OpenAI 兼容协议）
# DeepSeek: https://api.deepseek.com/v1
# 智谱 GLM:  https://open.bigmodel.cn/api/paas/v4
# 通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_LLM_BASE_URL=https://api.deepseek.com/v1

# API Key（从对应平台获取）
VITE_LLM_API_KEY=sk-your-api-key-here

# 模型名称
# DeepSeek: deepseek-chat
# 智谱 GLM:  glm-4-flash
# 通义千问:  qwen-turbo
VITE_LLM_MODEL=deepseek-chat

# ── 阿里云百炼实时语音识别配置 ────────────────────────────────
# 后端代理地址（前端连接此地址，后端转发到百炼 DashScope）
VITE_ASR_PROXY_URL=/asr-proxy